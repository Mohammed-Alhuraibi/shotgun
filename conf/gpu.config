/*
========================================================================================
    GPU-specific process overrides
    Included by the 'gpu' profile in nextflow.config
========================================================================================
    Server specs: 30 GB RAM, 12 CPUs, 1x RTX 5060 Ti (16 GB VRAM)
    Resources tuned accordingly
========================================================================================
*/

params {
    max_memory = '24.GB'
    max_cpus   = 8
    max_time   = '48.h'
}

process {

    // KNEADDATA (Bowtie2 alignment + Trimmomatic + TRF)
    withName: KNEADDATA {
        cpus        = 4
        memory      = '12.GB'
        accelerator = 1
        container   = 'quay.io/biocontainers/kneaddata:0.10.0--pyhdfd78af_0'
    }

    // CAT_FASTQ (lightweight concatenation)
    withName: 'CAT_FASTQ' {
        cpus   = 1
        memory = '2.GB'
    }

    // GPU-eligible compute-heavy processes (not running in this test, but configured)
    withName: KRAKEN2_RUN {
        cpus        = 4
        memory      = '16.GB'
        accelerator = 1
    }

    withName: CENTRIFUGE_RUN {
        cpus        = 4
        memory      = '12.GB'
        accelerator = 1
    }

    withName: KAIJU_RUN {
        cpus        = 4
        memory      = '16.GB'
        accelerator = 1
    }

    withName: METAPHLAN_RUN {
        cpus        = 4
        memory      = '8.GB'
        accelerator = 1
    }

    withName: MOTUS_RUN {
        cpus        = 4
        memory      = '12.GB'
        accelerator = 1
    }

    withName: HUMANN_RUN {
        cpus        = 4
        memory      = '12.GB'
        accelerator = 1
    }

    // Limit concurrent jobs
    withLabel: 'process_high' {
        cpus   = 4
        memory = '12.GB'
    }

    withLabel: 'process_medium' {
        cpus   = 2
        memory = '6.GB'
    }

    withLabel: 'process_low' {
        cpus   = 1
        memory = '2.GB'
    }

}

docker {
    enabled   = true
    runOptions = '--runtime=nvidia --shm-size=1g'
}
